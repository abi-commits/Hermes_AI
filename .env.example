# =============================================================================
# Hermes Voice Support Service - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=hermes
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# -----------------------------------------------------------------------------
# Twilio Settings
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Speech-to-Text (Deepgram)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# -----------------------------------------------------------------------------
# LLM (Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Text-to-Speech (Chatterbox)
# -----------------------------------------------------------------------------
CHATTERBOX_API_URL=http://localhost:8001
CHATTERBOX_VOICE=default
CHATTERBOX_SPEED=1.0

# Alternative TTS providers
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# -----------------------------------------------------------------------------
# Vector Database (ChromaDB)
# -----------------------------------------------------------------------------
VECTOR_DB_PROVIDER=chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8002
CHROMADB_COLLECTION=hermes_knowledge

# Alternative: Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX=hermes-knowledge

# -----------------------------------------------------------------------------
# Redis (for caching and queues)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/hermes

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_PORT=9090
ENABLE_PROMETHEUS=true

# -----------------------------------------------------------------------------
# Audio Settings
# -----------------------------------------------------------------------------
AUDIO_SAMPLE_RATE=8000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=20

# -----------------------------------------------------------------------------
# RAG Settings
# -----------------------------------------------------------------------------
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
