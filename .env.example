# =============================================================================
# Hermes Voice Support Service - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=hermes
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# -----------------------------------------------------------------------------
# Twilio Settings
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# E.164 number to dial when caller presses 0 (transfer to human agent)
TWILIO_TRANSFER_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Speech-to-Text (Deepgram)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# -----------------------------------------------------------------------------
# LLM (Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Text-to-Speech (Chatterbox Turbo)
# -----------------------------------------------------------------------------
# Device for Chatterbox model: 'auto', 'cuda', 'cpu', 'mps'
CHATTERBOX_DEVICE=auto
# Path to reference WAV file for voice cloning (optional)
CHATTERBOX_REFERENCE_AUDIO=
# Hex-encoded secret key for Perth audio watermarking (optional)
CHATTERBOX_WATERMARK_KEY=
# Number of concurrent TTS generation threads
CHATTERBOX_NUM_WORKERS=1

# Alternative TTS providers (optional)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Vector Database (ChromaDB)
# -----------------------------------------------------------------------------
VECTOR_DB_PROVIDER=chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8002
CHROMADB_COLLECTION=hermes_knowledge

# Chroma Cloud (set CHROMA_CLOUD_URL to enable cloud mode)
CHROMA_CLOUD_URL=
CHROMA_CLOUD_API_KEY=
CHROMA_TENANT=default
CHROMA_DATABASE=default

# Alternative: Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=hermes-knowledge

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/hermes

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_PORT=9090
ENABLE_PROMETHEUS=true

# -----------------------------------------------------------------------------
# Audio Settings
# -----------------------------------------------------------------------------
AUDIO_SAMPLE_RATE=8000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=20

# -----------------------------------------------------------------------------
# RAG Settings
# -----------------------------------------------------------------------------
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_USE_TOKEN_SPLITTING=false
RAG_TOKEN_ENCODING=cl100k_base
RAG_ENABLE_HYBRID_RETRIEVAL=false
RAG_BM25_WEIGHT=0.3
RAG_DEDUPLICATION=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Observability / Tracing
# -----------------------------------------------------------------------------
RAG_ENABLE_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hermes
